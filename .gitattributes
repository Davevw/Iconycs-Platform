# Prevent Windows Git from corrupting UTF-8 emoji bytes in source files
*.tsx text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.js text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf

# Binary files — never touch
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
