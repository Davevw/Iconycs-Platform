# ═══════════════════════════════════════════════
# ICONYCS Platform — Environment Variables
# Copy to .env.local and fill in your values
# NEVER commit .env.local to git
# ═══════════════════════════════════════════════

# ── Snowflake Connection ──
SNOWFLAKE_ACCOUNT=your_account.us-east-1
SNOWFLAKE_USER=ICONYCS_USER
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=PROPERTYANALYTICS
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_ROLE=ACCOUNTADMIN

# ── Claude AI (Anthropic) ──
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ── LinkedIn API ──
LINKEDIN_ACCESS_TOKEN=your_linkedin_token
LINKEDIN_PAGE_ID=your_page_id

# ── NextAuth (authentication) ──
NEXTAUTH_SECRET=generate-a-random-32-char-string
NEXTAUTH_URL=https://iconycs.com

# ── Site ──
NEXT_PUBLIC_SITE_URL=https://iconycs.com
